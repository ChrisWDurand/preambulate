{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.venv/bin/python $CLAUDE_PROJECT_DIR/capture.py",
            "statusMessage": "Capturing session..."
          }
        ]
      }
    ]
  }
}
